        ".": {
            "types": "./dist/index.d.mts",
            "default": "./dist/index.mjs"
        }
    },
    "dependencies": {
        "@basmilius/utils": "^2.12.0"
    },
    "devDependencies": {
        "tsdown": "^0.21.4",
        "typescript": "^5.9.3",
        "vite": "^6.3.1",
        "vitepress": "^1.6.3",
        "vitepress-plugin-example": "^1.4.0",
        "vitepress-plugin-render": "^1.4.0"
    }
